# ── LLM 配置 ────────────────────────────────────────────────────────────────
# 支持任意 OpenAI-compatible API（DeepSeek / 阿里百炼 / 本地等）
LLM_PROVIDER=custom
LLM_MODEL_ID=deepseek-chat
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TIMEOUT=60

# ── 搜索引擎 ─────────────────────────────────────────────────────────────────
# 可选：duckduckgo / tavily
SEARCH_API=duckduckgo
# TAVILY_API_KEY=tvly-xxxxx   # 使用 tavily 时填写

# ── 研究深度 ─────────────────────────────────────────────────────────────────
MAX_WEB_RESEARCH_LOOPS=3
FETCH_FULL_PAGE=True

# ── 服务器 ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
